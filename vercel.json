{
  "version": 2,
  "buildCommand": "npm run build && node scripts/build-vercel-output.mjs",
  "outputDirectory": "public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' https:; font-src 'self' data:; object-src 'none'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'; upgrade-insecure-requests"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=(), payment=()"
        }
      ]
    }
  ],
  "functions": {
    "api/index.mjs": { "maxDuration": 30 },
    "api/cron/maintenance.mjs": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/api/cron/maintenance", "destination": "/api/cron/maintenance.mjs" },
    { "source": "/api/:path*", "destination": "/api/index.mjs" },
    { "source": "/((?!dist|assets|styles\\.css).*)", "destination": "/index.html" }
  ],
  "crons": [
    { "path": "/api/cron/maintenance", "schedule": "0 3 * * *" }
  ]
}
