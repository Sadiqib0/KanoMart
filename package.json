{
  "name": "kano-mart",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "esbuild src/app.ts --bundle --outfile=dist/app.js --target=es2020 --format=iife",
    "dev": "esbuild src/app.ts --bundle --outfile=dist/app.js --target=es2020 --format=iife --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.6"
  }
}
