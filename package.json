{
  "name": "kano-mart",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && esbuild src/frontend/app.ts --bundle --outdir=dist --target=es2020 --format=esm --splitting",
    "api:dev": "node api/server.mjs",
    "api:dev:persist": "API_DATA_FILE=./data/kano-mart-api.json node api/server.mjs",
    "api:check": "node --check api/server.mjs",
    "dev": "esbuild src/frontend/app.ts --bundle --outdir=dist --target=es2020 --format=esm --splitting --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@vercel/blob": "^2.4.0"
  }
}
