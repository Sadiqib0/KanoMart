{
  "name": "kano-mart",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "npm run build --workspace=frontend",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "dev": "npm run dev:frontend & npm run dev:backend",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:verify": "node scripts/verify-db-backup.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "esbuild": "^0.28.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.4.0",
    "postgres": "^3.4.9"
  }
}
