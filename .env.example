# Kano Mart environment template.
# Copy this file to .env for local configuration. Never commit real secrets.

NODE_ENV=production
PORT=8787

# Frontend/API origin.
CORS_ORIGIN=https://your-frontend-domain.example
API_PUBLIC_BASE_PATH=/api

# Admin account. Preferred: seed it directly with scripts/reset-and-seed-admin.mjs.
# KANO_ADMIN_PHONE is optional — if set, registering with this exact phone number
# grants the admin role. Leave it UNSET in production once the admin is seeded.
KANO_ADMIN_PHONE=

# Paystack (https://dashboard.paystack.com → Settings → API Keys & Webhooks).
# When set, card/USSD checkouts go through Paystack hosted checkout and are only
# marked paid by the signed webhook (point Paystack at /api/payments/webhook/paystack).
# When unset in production, card/USSD/wallet orders stay "pending" for admin
# verification — they are never auto-marked paid.
PAYSTACK_SECRET_KEY=

# Set to "true" ONLY to deliberately run production without Upstash Redis
# (rate limits become per-instance). Otherwise the server refuses to start.
ALLOW_MEMORY_RATE_LIMIT=

# Production/serverless persistence.
DATABASE_URL=

# Product image storage. If unset, uploads fall back to API-served database storage
# (acceptable for local dev and small pilots; use Vercel Blob in production).
BLOB_READ_WRITE_TOKEN=

# Rate limiting via Upstash Redis.
# Create a free Redis database at https://console.upstash.com and copy the REST URL + token.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Cron job authentication — set a random secret (e.g. openssl rand -hex 32).
# Vercel automatically passes this in the Authorization header for cron invocations.
CRON_SECRET=

# Snapshot store for in-memory/serverless persistence fallback (Upstash Redis key).
# Only required if running without a Postgres DATABASE_URL.
API_STORE_REST_URL=
API_STORE_REST_TOKEN=
API_STORE_KEY=kano:store

# Local long-running Node fallback only. Do not use this on Vercel.
API_DATA_FILE=./data/kano-mart-api.json

# Runtime limits and hardening.
# The frontend compresses vendor product images below 700k data-url characters.
API_BODY_LIMIT_BYTES=1000000
API_UPLOAD_MAX_DATA_URL_LENGTH=750000
API_RATE_LIMIT_WINDOW_MS=60000
API_RATE_LIMIT_MAX=600
# Per-user rate limit (requests per window). Defaults to 60 if unset.
API_USER_RATE_LIMIT_MAX=60
PASSWORD_HASH_ITERATIONS=210000

# Postgres connection tuning (optional — sensible defaults apply if unset).
# DB_POOL_MAX: max simultaneous connections per serverless instance.
# DB_STATEMENT_TIMEOUT_MS: hard timeout per SQL statement (ms).
DB_POOL_MAX=5
DB_STATEMENT_TIMEOUT_MS=8000

# Transactional email via Resend (https://resend.com).
# Leave blank to skip email sending in local dev — the app functions without it.
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.example

# Server error monitoring — get a free DSN at https://sentry.io
# Create a project → Settings → Client Keys → DSN.
SENTRY_DSN=
